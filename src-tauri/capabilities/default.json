{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "platforms": [
    "windows",
    "macOS",
    "linux"
  ],
  "windows": [
    "qr_maker",
    "updater"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    "notification:default",
    "updater:default",
    "core:window:allow-close",
    "process:allow-restart",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}