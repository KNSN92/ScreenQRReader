{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenQRReader",
  "version": "0.1.2",
  "identifier": "com.screenqrreader",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["i18n/*"],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2QTU2QjE4OUYwQUMyNkMKUldSc3dncWZHR3VsRnZaS2U3OWdqdXlNWmZXeHZjeFNyYXY4MHV3eFB6REtmSlY1R3gxUmVyWTUK",
      "endpoints": [
        "https://github.com/KNSN92/ScreenQRReader/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
