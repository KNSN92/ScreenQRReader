{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScreenQRReader",
  "version": "0.2.0",
  "identifier": "com.screenqrreader",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": {
        "img-src": "'self' asset: http://asset.localhost blob: data:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["i18n/*"],
    "macOS": {
      "signingIdentity": "-"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI1QjU5Q0JFOEE2QkE0MEQKUldRTnBHdUt2cHkxSlJWSThTZ0haRDJ4V3NQZERzcjkxNnNkcy9Fa2c3U1dBZXZCZXBmS0E5dmMK",
      "endpoints": [
        "https://github.com/KNSN92/ScreenQRReader/releases/latest/download/latest.json"
      ]
    }
  }
}
